{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    // Workers runtime, not the browser DOM — workers-types provides the globals
    // (WebSocketPair, DurableObjectState, …). Including DOM would clash with them.
    "lib": ["ES2022"],
    "types": ["@cloudflare/workers-types"],
    "noEmit": true
  },
  "include": ["src"]
}
