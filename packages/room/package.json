{
  "name": "@captions/room",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "CaptionRoom Durable Object — v2 audience/streaming transport. Runs standalone (own Worker) or composed into the same-origin v2 Worker.",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "verify": "node scripts/verify.mjs"
  },
  "dependencies": {
    "@captions/protocol": "workspace:*"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241127.0",
    "wrangler": "^4.0.0"
  }
}
